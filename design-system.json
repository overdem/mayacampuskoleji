    "status": {
      "success": "#059669",
      "error": "#DC2626",
      "warning": "#F59E0B",
      "info": "#0EA5E9"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "Poppins, sans-serif",
      "body": "Inter, sans-serif",
      "mono": "'Courier New', monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px",
      "4xl": "36px"
    },
    "fontWeight": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2
    },
    "headings": {
      "h1": {
        "fontSize": "36px",
        "fontWeight": 700,
        "lineHeight": 1.2,
        "fontFamily": "Poppins"
      },
      "h2": {
        "fontSize": "30px",
        "fontWeight": 700,
        "lineHeight": 1.2,
        "fontFamily": "Poppins"
      },
      "h3": {
        "fontSize": "24px",
        "fontWeight": 700,
        "lineHeight": 1.3,
        "fontFamily": "Poppins"
      },
      "h4": {
        "fontSize": "20px",
        "fontWeight": 600,
        "lineHeight": 1.4,
        "fontFamily": "Poppins"
      },
      "body": {
        "fontSize": "14px",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "fontFamily": "Inter"
      },
      "small": {
        "fontSize": "12px",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "fontFamily": "Inter"
      }
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "base": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "24px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "base": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)"
  },
  "transitions": {
    "fast": "150ms ease-in-out",
    "base": "200ms ease-in-out",
    "slow": "300ms ease-in-out"
  },
  "breakpoints": {
    "mobile": "320px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "components": {
    "button": {
      "variants": ["primary", "secondary", "danger", "ghost"],
      "sizes": ["sm", "md", "lg"],
      "states": ["default", "hover", "active", "disabled"]
    },
    "input": {
      "types": ["text", "email", "password", "number", "date"],
      "sizes": ["sm", "md", "lg"],
      "states": ["default", "focus", "error", "disabled"]
    },
    "card": {
      "variants": ["default", "elevated", "outlined"],
      "borderRadius": "12px"
    },
    "modal": {
      "backdrop": "rgba(0, 0, 0, 0.5)",
      "borderRadius": "12px"
    },
    "badge": {
      "variants": ["default", "success", "error", "warning", "info"],
      "sizes": ["sm", "md"]
    },
    "pagination": {
      "itemSize": "40px",
      "activeColor": "#1E40AF"
    }
  }
}
